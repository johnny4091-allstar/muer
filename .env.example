# Database
POSTGRES_PASSWORD=changeme_strong_password_here

# Redis
REDIS_PASSWORD=changeme_redis_password_here

# NextAuth
NEXTAUTH_SECRET=changeme_32_char_secret_here
NEXTAUTH_URL=https://your-domain.com

# Device API security
DEVICE_API_KEY_SALT=changeme_device_salt_here

# Internal cron secret (same as NEXTAUTH_SECRET is fine)
CRON_SECRET=changeme_cron_secret_here

# Computed by docker-compose — do not set manually
# DATABASE_URL=postgresql://iptvsaas:${POSTGRES_PASSWORD}@postgres:5432/iptvsaas
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
