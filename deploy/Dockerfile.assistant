# =============================================================================
# Muer Voice Assistant — Docker Image
# Build: docker build -f deploy/Dockerfile.assistant -t muer-assistant .
# Run:   docker run --device /dev/snd -e ANTHROPIC_API_KEY=... muer-assistant
# =============================================================================

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    portaudio19-dev \
    espeak \
    espeak-data \
    libespeak-dev \
    mpv \
    ffmpeg \
    libsndfile1 \
    pulseaudio-utils \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install yt-dlp
RUN curl -sL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp \
    -o /usr/local/bin/yt-dlp && chmod +x /usr/local/bin/yt-dlp

WORKDIR /app

# Install Python dependencies first (layer caching)
COPY assistant/requirements.txt /app/assistant/requirements.txt
RUN pip3 install --no-cache-dir -r /app/assistant/requirements.txt

# Copy application source
COPY assistant/ /app/assistant/
COPY .env.sample /app/.env

# PulseAudio config for Docker audio passthrough
RUN echo "default-server = unix:/run/user/1000/pulse/native" > /etc/pulse/client.conf

ENV PYTHONPATH=/app

# Run in text mode by default; override CMD for production
CMD ["python3", "-m", "assistant.main", "--no-wake"]
