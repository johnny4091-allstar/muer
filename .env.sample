# ─── YouTube Data API v3 ───────────────────────────────────────────────────────
# Get your key at: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY="your_youtube_data_api_v3_key_here"

# ─── Admin panel ───────────────────────────────────────────────────────────────
# Password for the /admin panel. Choose something strong.
ADMIN_PASSWORD="change_me_to_a_strong_password"

# ─── Session ───────────────────────────────────────────────────────────────────
# Random secret used to sign session cookies. Must be at least 32 chars.
SESSION_SECRET="change_me_to_a_random_32_char_string"

# ─── Supabase (optional – only needed for user auth features) ──────────────────
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""
