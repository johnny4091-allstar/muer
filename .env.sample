SUPABASE_SERVICE_KEY=""

# =============================================================================
# Muer Voice Assistant Configuration
# =============================================================================

# Claude API key (required for smart NLP and Q&A)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Assistant identity
ASSISTANT_NAME="Muer"
WAKE_WORD="hey_jarvis"
WAKE_WORD_THRESHOLD="0.5"

# Speech-to-text: Whisper model size (tiny|base|small|medium|large)
# larger = more accurate but slower; "base" recommended for most systems
STT_MODEL="base"
STT_DEVICE="cpu"

# Audio device index (leave blank to use system default)
AUDIO_DEVICE_INDEX=""

# TTS speech rate (words per minute)
TTS_RATE="175"

# Weather skill (optional)
# Get a free key at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=""
DEFAULT_WEATHER_CITY="New York"
WEATHER_LAT=""
WEATHER_LON=""

# News skill (optional — falls back to free BBC RSS without a key)
# Get a free key at: https://newsapi.org/
NEWS_API_KEY=""

# Smart Home — Home Assistant (optional)
# Your Home Assistant instance URL and long-lived access token
HA_URL=""
HA_TOKEN=""

# Data persistence directory for lists, notes, alarms, reminders
DATA_DIR="~/.config/muer-assistant"

# Follow-up mode: seconds to keep listening after a response (0 to disable)
FOLLOW_UP_SECONDS="5"

# =============================================================================
# Auto-Updater Configuration
# =============================================================================

# Enable automatic git-based updates (polls every AUTO_UPDATE_INTERVAL seconds)
AUTO_UPDATE_ENABLED="true"
AUTO_UPDATE_INTERVAL="300"

# Git branch and remote to track
GIT_BRANCH="claude/voice-assistant-ubuntu-Nn1c7"
GIT_REMOTE="origin"

# GitHub webhook (optional — enables instant updates on git push)
# Set this secret in GitHub repo → Settings → Webhooks → Secret
WEBHOOK_SECRET=""
WEBHOOK_PORT="9000"

# Logging
LOG_LEVEL="INFO"
LOG_FILE="/tmp/muer-assistant.log"